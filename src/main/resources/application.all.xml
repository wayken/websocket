<?xml version="1.0" encoding="UTF-8"?>
<bootor-config>
    <!-- 基础配置 -->
    <!-- 扫描基础包，必须配置，框架会自动扫描注解类 -->
    <property name="basePackage">cloud.apposs.websocket.sample</property>
    <!-- 项目输入输出编码 -->
    <property name="charset">utf-8</property>
    <!-- 绑定主机和端口 -->
    <property name="host">0.0.0.0</property>
    <property name="port">7012</property>
    <property name="keepAlive">true</property>
    <!-- 分布式部署配置相关 -->
    <property name="distributedType">redission</property>
    <property name="distributedServerAddress">192.168.5.57:6030</property>
</bootor-config>